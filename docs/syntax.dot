digraph syntax {
	rankdir=LR;
	node [ shape = point ];
	ENTRY;
	en_4;
	en_5;
	en_1;
	node [ shape = circle, height = 0.2 ];
	node [ fixedsize = true, height = 0.65, shape = doublecircle ];
	9;
	10;
	11;
	node [ shape = circle ];
	1 -> 2 [ label = "'{'" ];
	2 -> 3 [ label = "'f'" ];
	2 -> 9 [ label = "'}'" ];
	3 -> 2 [ label = "',', ';'" ];
	3 -> 9 [ label = "'}'" ];
	4 -> 10 [ label = "'e'" ];
	5 -> 6 [ label = "'('" ];
	6 -> 11 [ label = "')'" ];
	6 -> 7 [ label = "'e'" ];
	7 -> 11 [ label = "')'" ];
	7 -> 8 [ label = "','" ];
	8 -> 7 [ label = "'e'" ];
	10 -> 4 [ label = "','" ];
	ENTRY -> 1 [ label = "IN" ];
	en_4 -> 4 [ label = "explist" ];
	en_5 -> 5 [ label = "args" ];
	en_1 -> 1 [ label = "tableconstructor" ];
}
